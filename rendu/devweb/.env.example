# Copier ce fichier en ".env" a cote de docker-compose.yml pour surcharger
# les valeurs par defaut lues par `docker compose up`.

# URL du serveur Ollama expose par l'equipe INFRA, joignable depuis le conteneur.
# Docker Desktop (Windows/Mac): http://host.docker.internal:11434 (defaut)
# Linux: idem, grace a l'entree extra_hosts du docker-compose.yml
# Reseau partage / IP fournie par l'INFRA: http://<ip-infra>:11434
OLLAMA_URL=http://host.docker.internal:11434

# Nom du modele cree par l'equipe INFRA via `ollama create <nom> -f ollama_server/Modelfile`
OLLAMA_MODEL=phi3.5-financial
