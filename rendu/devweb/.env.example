# Copier ce fichier en ".env" a cote de docker-compose.yml pour surcharger
# les valeurs par defaut lues par `docker compose up`.

# URL du serveur Ollama, joignable depuis le conteneur "back".
# Lance depuis la racine du repo (docker-compose.yml qui inclut ce fichier,
# avec le service "ollama" de l'INFRA) : http://ollama:11434 (nom du service
# sur le reseau Docker interne du projet) -- c'est la valeur par defaut.
# Lance en standalone (mock local ou Ollama sur l'hote, depuis rendu/devweb/) :
# remplacer par http://host.docker.internal:11434 (Docker Desktop, ou Linux
# grace a l'entree extra_hosts du docker-compose.yml), ou par l'IP fournie par l'INFRA.
OLLAMA_URL=http://ollama:11434

# Nom du modele cree par l'equipe INFRA via `ollama create <nom> -f ollama_server/Modelfile`
OLLAMA_MODEL=phi3.5-financial
