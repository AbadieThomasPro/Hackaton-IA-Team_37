# URL du serveur Ollama expose par l'equipe INFRA
# Docker Desktop (Windows/Mac): http://host.docker.internal:11434
# Linux (avec --add-host=host.docker.internal:host-gateway): idem
# Reseau partage / IP fournie par l'INFRA: http://<ip-infra>:11434
OLLAMA_URL=http://localhost:11434

# Nom du modele cree par l'equipe INFRA via `ollama create <nom> -f ollama_server/Modelfile`
OLLAMA_MODEL=phi3.5-financial

# Port d'ecoute de l'API Express (et de l'app servie en prod)
PORT=3000
